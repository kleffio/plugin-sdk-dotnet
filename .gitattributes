# Normalise line endings to LF in the repo; check out as-is on all platforms
* text=auto eol=lf
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.md text eol=lf
*.proto text eol=lf

# Binaries — no conversion
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snupkg binary
